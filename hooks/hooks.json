{
  "description": "claude-remote plugin hooks",
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PLUGIN_ROOT\"/hooks/permission-handler.mjs",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
